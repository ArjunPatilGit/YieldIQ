rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * YieldIQ Security Rules
     * 
     * Philosophy:
     * - Users have absolute ownership over their own data hierarchy.
     * - Root user profile is accessible immediately to allow signup flows.
     * - All nested agricultural and AI data requires a verified email address.
     */

    // --- Core User Data ---
    match /users/{userId} {
      // Allow the owner to manage their root profile (required for signup and verification)
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Secure all nested collections (farms, fields, logs, etc.)
      // These REQUIRE the owner's email to be verified.
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null 
          && request.auth.uid == userId;
      }
    }

    // --- Global Reference Data ---
    // Accessible by any verified user
    match /crop_types/{id} {
      allow read: if request.auth != null;
    }
    
    match /seasons/{id} {
      allow read: if request.auth != null;
    }
    
    match /consultant_profiles/{id} {
      allow read: if request.auth != null;
    }

    // --- Collection Groups ---
    // Allows consultants to see requests assigned specifically to them
    match /{path=**}/consultation_requests/{id} {
      allow read: if request.auth != null 
        && resource.data.consultantId == request.auth.uid;
    }
  }
}